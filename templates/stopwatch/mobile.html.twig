{% extends 'base.html.twig' %}

{% block title %}Stoppuhr – {{ game.name }}{% endblock %}

{% block body %}
<div class="max-w-md mx-auto">
    <!-- Header -->
    <div class="text-center mb-6">
        <h1 class="text-2xl font-extrabold gradient-text">{{ game.name }}</h1>
        <p class="text-gray-400 mt-1">Stoppe die Zeit so genau wie möglich!</p>
    </div>

    <!-- Zielzeit -->
    <div class="card card-highlight p-6 text-center mb-6">
        <div class="text-sm uppercase tracking-widest text-purple-300 font-semibold mb-1">Zielzeit</div>
        <div class="text-5xl font-black text-amber-400" id="target-display">{{ game.stopwatchTarget|number_format(2, ',', '') }}<span class="text-2xl text-amber-300"> s</span></div>
        <p class="text-gray-500 text-sm mt-2">Die laufende Uhr ist unsichtbar – zähl im Kopf mit! </p>
    </div>

    {% if not game.isActive %}
        <div class="card p-6 text-center">
            <p class="text-gray-300">Das Spiel ist nicht aktiv.</p>
            {% if game.isCompleted %}
                <a href="{{ path('app_stopwatch_results', {gameId: game.id}) }}" class="btn-primary mt-4">Zu den Ergebnissen</a>
            {% endif %}
        </div>
    {% else %}
        <!-- Schritt 1: Spieler wählen (entfällt bei Auto-Join vom Dashboard) -->
        <div id="step-player" class="card p-6 {{ preselected_player is defined and preselected_player ? 'hidden' : '' }}">
            <h2 class="text-lg font-bold text-gray-100 mb-4">Wer bist du?</h2>
            <div class="grid grid-cols-1 gap-3">
                {% for player in players %}
                    {% if player.id in submitted_player_ids %}
                        <button disabled
                                class="w-full min-h-[52px] px-4 rounded-xl bg-night-700/40 border border-gray-700 text-gray-500 font-semibold flex items-center justify-between cursor-not-allowed">
                            <span>{{ player.name }}</span>
                            <span class="text-emerald-400">fertig</span>
                        </button>
                    {% else %}
                        <button data-player-id="{{ player.id }}" data-player-name="{{ player.name }}"
                                class="player-select-btn w-full min-h-[52px] px-4 rounded-xl bg-night-700/70 border border-party-purple/30 text-gray-100 font-semibold hover:border-party-purple hover:bg-night-600/70 transition-all flex items-center justify-between">
                            <span>{{ player.name }}</span>
                        </button>
                    {% endif %}
                {% endfor %}
            </div>
        </div>

        <!-- Schritt 2: Stoppuhr -->
        <div id="step-play" class="{{ preselected_player is defined and preselected_player ? '' : 'hidden' }}">
            <div class="card p-6 text-center mb-4">
                <div class="text-sm text-gray-400 mb-1">Spieler</div>
                <div class="text-xl font-bold text-gray-100" id="active-player-name">{{ preselected_player is defined and preselected_player ? preselected_player.name : '' }}</div>
            </div>

            <div class="card p-8 text-center">
                <button id="stopwatch-btn"
                        class="w-52 h-52 mx-auto rounded-full text-3xl font-black text-white transition-all duration-200 shadow-2xl
                               bg-emerald-700 hover:bg-emerald-600 active:scale-95">
                    START
                </button>
                <p id="stopwatch-hint" class="text-gray-500 text-sm mt-6">Drücke START und stoppe möglichst genau bei <strong class="text-amber-400">{{ game.stopwatchTarget|number_format(2, ',', '') }} s</strong></p>
            </div>
        </div>

        <!-- Schritt 3: Ergebnis -->
        <div id="step-result" class="hidden">
            <div class="card card-highlight p-8 text-center">
                <h2 class="text-xl font-bold text-gray-100 mb-6">Deine Zeit ist gespeichert</h2>

                <div class="grid grid-cols-2 gap-4 mb-6">
                    <div class="bg-night-700/50 rounded-xl p-4">
                        <div class="text-xs uppercase tracking-wider text-gray-500 mb-1">Deine Zeit</div>
                        <div class="text-2xl font-extrabold text-gray-100" id="result-elapsed">–</div>
                    </div>
                    <div class="bg-night-700/50 rounded-xl p-4">
                        <div class="text-xs uppercase tracking-wider text-gray-500 mb-1">Abweichung</div>
                        <div class="text-2xl font-extrabold text-pink-400" id="result-deviation">–</div>
                    </div>
                </div>

                <div id="waiting-info" class="text-gray-400 text-sm">
                    <div class="loading-spinner mx-auto mb-2"></div>
                    <span id="waiting-text">Warte auf die anderen Spieler…</span>
                </div>

                <a id="results-link" href="{{ path('app_stopwatch_results', {gameId: game.id}) }}" class="btn-primary mt-4 hidden">
                    Zu den Ergebnissen
                </a>
            </div>
        </div>

        <div id="submit-error" class="hidden flash-message flash-error mt-4"></div>
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
{% if game.isActive %}
<script>
    (function () {
        const gameId = {{ game.id }};
        const dashboardBase = '/player-dashboard/{{ game.olympix.id }}/';
        let selectedPlayerId = {{ preselected_player is defined and preselected_player ? preselected_player.id : 'null' }};
        let startTimestamp = null;
        let running = false;

        const stepPlayer = document.getElementById('step-player');
        const stepPlay = document.getElementById('step-play');
        const stepResult = document.getElementById('step-result');
        const stopwatchBtn = document.getElementById('stopwatch-btn');
        const errorBox = document.getElementById('submit-error');

        // Geräte-Identität: einmal Namen gewählt = dieses Handy IST dieser Spieler (24h)
        const identityKey = 'olympix_{{ game.olympix.id }}_selected_player';

        function saveIdentity(id, name) {
            localStorage.setItem(identityKey, JSON.stringify({ id: parseInt(id, 10), name: name, points: 0, timestamp: Date.now() }));
        }

        function readIdentity() {
            try {
                const d = JSON.parse(localStorage.getItem(identityKey) || 'null');
                if (d && d.id && d.timestamp && d.timestamp > Date.now() - 24 * 60 * 60 * 1000) return d;
            } catch (e) {}
            return null;
        }

        function activatePlayer(id, name) {
            selectedPlayerId = parseInt(id, 10);
            document.getElementById('active-player-name').textContent = name;
            stepPlayer.classList.add('hidden');
            stepPlay.classList.remove('hidden');
        }

        document.querySelectorAll('.player-select-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                saveIdentity(btn.dataset.playerId, btn.dataset.playerName);
                activatePlayer(btn.dataset.playerId, btn.dataset.playerName);
            });
        });

        if (selectedPlayerId) {
            // Server-seitig vorausgewählt (Auto-Join): Identität auffrischen
            saveIdentity(selectedPlayerId, document.getElementById('active-player-name').textContent);
        } else {
            // Gespeicherte Geräte-Identität anwenden — Namensauswahl überspringen
            const identity = readIdentity();
            if (identity) {
                const btn = document.querySelector(`.player-select-btn[data-player-id="${identity.id}"]`);
                if (btn) {
                    activatePlayer(identity.id, btn.dataset.playerName);
                } else if (document.querySelector(`[data-player-id]`) || document.getElementById('step-player')) {
                    // Spieler hat schon abgegeben (kein aktiver Button mehr) -> zurück zum Dashboard
                    const submitted = {{ submitted_player_ids|json_encode }};
                    if (submitted.includes(identity.id)) {
                        window.location.href = '/player-dashboard/{{ game.olympix.id }}/' + identity.id;
                    }
                }
            }
        }

        stopwatchBtn.addEventListener('click', () => {
            if (!running) {
                running = true;
                startTimestamp = performance.now();
                stopwatchBtn.textContent = 'STOP';
                stopwatchBtn.classList.remove('bg-emerald-700', 'hover:bg-emerald-600');
                stopwatchBtn.classList.add('bg-red-700', 'hover:bg-red-600', 'animate-pulse');
            } else {
                const elapsed = (performance.now() - startTimestamp) / 1000;
                running = false;
                stopwatchBtn.disabled = true;
                stopwatchBtn.classList.remove('animate-pulse');
                submitTime(elapsed);
            }
        });

        function submitTime(elapsed) {
            fetch(`/stopwatch/submit/${gameId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    player_id: selectedPlayerId,
                    elapsed_seconds: Math.round(elapsed * 100) / 100,
                }),
            })
                .then(r => r.json())
                .then(data => {
                    if (!data.success) {
                        showError(data.error || 'Unbekannter Fehler');
                        return;
                    }

                    stepPlay.classList.add('hidden');
                    stepResult.classList.remove('hidden');

                    document.getElementById('result-elapsed').textContent =
                        parseFloat(data.elapsed).toFixed(2).replace('.', ',') + ' s';
                    document.getElementById('result-deviation').textContent =
                        (data.deviation >= 0 ? '±' : '') + parseFloat(data.deviation).toFixed(2).replace('.', ',') + ' s';

                    const deviation = parseFloat(data.deviation);
                    if (data.game_completed) {
                        showResultsLink();
                    } else {
                        pollForCompletion();
                    }
                })
                .catch(() => showError('Netzwerkfehler – bitte erneut versuchen'));
        }

        function showError(message) {
            errorBox.textContent = '' + message;
            errorBox.classList.remove('hidden');
            stopwatchBtn.disabled = false;
            stopwatchBtn.textContent = 'START';
            stopwatchBtn.classList.add('bg-emerald-700', 'hover:bg-emerald-600');
            stopwatchBtn.classList.remove('bg-red-700', 'hover:bg-red-600');
        }

        function showResultsLink() {
            document.getElementById('waiting-info').classList.add('hidden');
            const resultsLink = document.getElementById('results-link');
            // Spieler-Kontext mitgeben: Ergebnisseite zeigt dann den Dashboard-Link statt Admin
            if (selectedPlayerId && !resultsLink.href.includes('player=')) {
                resultsLink.href += '?player=' + selectedPlayerId;
            }
            resultsLink.classList.remove('hidden');

            // Automatisch zurück zum Dashboard — dort erscheint das nächste Spiel von selbst
            if (selectedPlayerId) {
                setTimeout(() => {
                    window.location.href = dashboardBase + selectedPlayerId;
                }, 5000);
            }
        }

        function pollForCompletion() {
            const interval = setInterval(() => {
                fetch(`/api/stopwatch/${gameId}/status`)
                    .then(r => r.json())
                    .then(data => {
                        document.getElementById('waiting-text').textContent =
                            `Warte auf die anderen Spieler… (${data.submitted_count}/${data.total_players})`;
                        if (data.is_completed) {
                            clearInterval(interval);
                            showResultsLink();
                        }
                    })
                    .catch(() => {});
            }, 3000);
        }
    })();
</script>
{% endif %}
{% endblock %}
