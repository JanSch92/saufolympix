{% extends 'base.html.twig' %}

{% block title %}Stoppuhr-Ergebnisse – {{ game.name }}{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto">
    <div class="text-center mb-8">
        <h1 class="text-3xl font-extrabold gradient-text">{{ game.name }}</h1>
        <p class="text-gray-400 mt-2">
            Zielzeit: <span class="text-amber-400 font-bold">{{ game.stopwatchTarget|number_format(2, ',', '') }} s</span>
        </p>
    </div>

    <div class="card p-6 mb-8">
        <h2 class="text-xl font-bold text-gray-100 mb-6">Rangliste</h2>

        {% if ranked_attempts is empty %}
            <p class="text-gray-500 text-center py-8">Keine Abgaben vorhanden.</p>
        {% else %}
            <div class="space-y-3">
                {% for attempt in ranked_attempts %}
                    {% set position = loop.index %}
                    <div class="flex items-center justify-between rounded-xl p-4 {{ position == 1 ? 'bg-amber-500/10 border border-amber-500/40' : 'bg-night-700/40 border border-gray-700/60' }}">
                        <div class="flex items-center gap-4 min-w-0">
                            <div class="ranking-badge {{ position == 1 ? 'ranking-1' : position == 2 ? 'ranking-2' : position == 3 ? 'ranking-3' : 'ranking-default' }}">
                                {{ position }}
                            </div>
                            <div class="min-w-0">
                                <div class="font-bold text-gray-100 truncate">
                                    {{ attempt.player.name }}
                                </div>
                                <div class="text-sm text-gray-400">
                                    {{ attempt.elapsedSeconds|number_format(2, ',', '') }} s
                                </div>
                            </div>
                        </div>
                        <div class="text-right shrink-0">
                            <div class="font-extrabold {{ attempt.deviation < 0.5 ? 'text-emerald-400' : attempt.deviation < 2 ? 'text-amber-400' : 'text-pink-400' }}">
                                ± {{ attempt.deviation|number_format(2, ',', '') }} s
                            </div>
                            <div class="text-xs text-gray-500">Abweichung</div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    {% if game.gameResults|length > 0 %}
        <div class="card p-6 mb-8">
            <h2 class="text-xl font-bold text-gray-100 mb-4">Vergebene Punkte</h2>
            <div class="space-y-2">
                {% for result in game.gameResults|sort((a, b) => a.position <=> b.position) %}
                    <div class="flex items-center justify-between px-4 py-2 rounded-lg bg-night-700/30">
                        <span class="text-gray-200">{{ result.position }}. {{ result.player.name }}
                            {% if result.jokerDoubleApplied %}<span class="text-xs ml-2 px-2 py-0.5 rounded-full bg-emerald-500/20 text-emerald-300">2x Joker</span>{% endif %}
                        </span>
                        <span class="font-bold text-amber-400">+{{ result.finalPoints }} Punkte</span>
                    </div>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    <div class="text-center">
        <a href="{{ path('app_game_admin', {id: game.olympix.id}) }}" class="btn-primary">← Zurück zum Admin</a>
    </div>
</div>
{% endblock %}
