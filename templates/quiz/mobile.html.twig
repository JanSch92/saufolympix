{% extends 'base.html.twig' %}

{% block title %}{{ game.name }} - Quiz{% endblock %}

{% block body %}
<div class="quiz-mobile min-h-screen flex items-center justify-center p-4">
    <div class="quiz-card w-full max-w-md p-6">
        <div class="text-center mb-6">
            <h1 class="text-2xl font-extrabold gradient-text">{{ game.name }}</h1>
            <p class="text-gray-400 mt-2">Quiz-Teilnahme</p>
        </div>

        <form method="POST" id="quizForm">
            <!-- Player Selection -->
            <div class="mb-6">
                <label for="player_id" class="block text-sm font-medium text-gray-300 mb-2">
                    Wähle deinen Namen
                </label>
                <select id="player_id"
                        name="player_id"
                        required
                        class="w-full">
                    <option value="">Bitte wählen</option>
                    {% for player in players %}
                        <option value="{{ player.id }}">{{ player.name }}</option>
                    {% endfor %}
                </select>
            </div>

            <!-- Questions -->
            <div class="space-y-6">
                {% for question in questions %}
                    <div class="bg-night-700/40 border border-gray-700/60 rounded-xl p-4">
                        <label for="answer_{{ question.id }}" class="block text-sm font-medium text-gray-300 mb-2">
                            {{ loop.index }}. {{ question.question }}
                        </label>
                        <input type="number"
                               id="answer_{{ question.id }}"
                               name="answer_{{ question.id }}"
                               step="0.01"
                               required
                               placeholder="Deine Schätzung"
                               class="w-full text-lg">
                    </div>
                {% endfor %}
            </div>

            <!-- Submit Button -->
            <div class="mt-8">
                <button type="submit"
                        class="btn-primary w-full text-lg"
                        onclick="return validateQuizForm()">
                    Antworten abschicken
                </button>
            </div>
        </form>

        <div class="mt-4 text-center">
            <div class="text-sm text-gray-400">
                Tipp: Je näher deine Schätzung an der korrekten Antwort liegt, desto mehr Punkte erhältst du!
            </div>
        </div>
    </div>
</div>

<script>
function validateQuizForm() {
    const playerId = document.getElementById('player_id').value;
    const answerInputs = document.querySelectorAll('input[name^="answer_"]');

    if (!playerId) {
        alert('Bitte wähle deinen Namen aus!');
        return false;
    }

    let allAnswered = true;
    answerInputs.forEach(input => {
        if (!input.value.trim()) {
            allAnswered = false;
        }
    });

    if (!allAnswered) {
        alert('Bitte beantworte alle Fragen!');
        return false;
    }

    return confirm('Antworten wirklich abschicken? Sie können nicht mehr geändert werden.');
}
</script>
{% endblock %}