{% extends 'base.html.twig' %}

{% block title %}📱 Quiz QR-Code - {{ game.name }}{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto">
    <!-- Header -->
    <div class="card p-6 mb-8">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-extrabold gradient-text">🧠 Quiz QR-Code</h1>
                <p class="text-gray-400 mt-1">{{ game.name }}</p>
            </div>
            <div class="flex space-x-4">
                <a href="{{ path('app_quiz_results', {gameId: game.id}) }}"
                   class="btn-secondary">
                    📊 Ergebnisse
                </a>
                <a href="{{ path('app_game_admin', {id: game.olympix.id}) }}"
                   class="btn-primary">
                    ← Zurück
                </a>
            </div>
        </div>
    </div>

    <!-- QR Code Display -->
    <div class="card p-8">
        <div class="text-center">
            <h2 class="text-2xl font-bold text-gray-100 mb-6">
                📱 Scannt den QR-Code mit eurem Handy
            </h2>

            <div class="qr-code-container mb-6">
                <div id="qrcode"></div>
            </div>

            <div class="bg-party-purple/10 border border-party-purple/30 rounded-lg p-4 mb-6">
                <h3 class="text-lg font-semibold text-purple-300 mb-2">✨ So funktioniert's:</h3>
                <ol class="text-left text-purple-200 space-y-2">
                    <li>1. QR-Code mit dem Handy scannen</li>
                    <li>2. Euren Namen auswählen</li>
                    <li>3. Alle Fragen beantworten</li>
                    <li>4. Abschicken und warten</li>
                </ol>
            </div>

            <div class="text-center">
                <div class="text-sm text-gray-400 mb-4">
                    Direkt-Link zum Quiz:
                </div>
                <div class="bg-night-700/40 border border-gray-700/60 text-gray-300 p-3 rounded-lg text-sm break-all">
                    {{ quiz_url }}
                </div>
            </div>
        </div>
    </div>

    <!-- Quiz Status -->
    <div class="card p-6 mt-8">
        <h3 class="text-lg font-bold text-gray-100 mb-4">📊 Quiz-Status</h3>

        <div id="quizStatus" class="space-y-4">
            <!-- Status wird via JavaScript geladen -->
        </div>

        <div class="mt-6 flex justify-center">
            <a href="{{ path('app_quiz_calculate', {gameId: game.id}) }}"
               class="btn-success">
                🧮 Ergebnisse berechnen
            </a>
        </div>
    </div>
</div>

<script>
// Generate QR Code
document.addEventListener('DOMContentLoaded', function() {
    generateQRCode('{{ quiz_url }}', 'qrcode');

    // Load quiz status
    loadQuizStatus();

    // Auto-refresh status every 5 seconds
    setInterval(loadQuizStatus, 5000);
});

function loadQuizStatus() {
    fetch('/api/quiz/{{ game.id }}/status')
        .then(response => response.json())
        .then(data => {
            updateQuizStatus(data);
        })
        .catch(error => {
            console.error('Error loading quiz status:', error);
        });
}

function updateQuizStatus(data) {
    const container = document.getElementById('quizStatus');
    let html = '';

    html += `
        <div class="flex items-center justify-between p-4 bg-night-700/40 border border-gray-700/60 rounded-lg">
            <div>
                <div class="font-medium text-gray-100">Gesamt-Teilnehmer</div>
                <div class="text-sm text-gray-400">${data.total_players} Spieler</div>
            </div>
            <div class="text-2xl font-bold text-amber-400">${data.total_players}</div>
        </div>

        <div class="flex items-center justify-between p-4 bg-night-700/40 border border-gray-700/60 rounded-lg">
            <div>
                <div class="font-medium text-gray-100">Fragen</div>
                <div class="text-sm text-gray-400">Anzahl Quiz-Fragen</div>
            </div>
            <div class="text-2xl font-bold text-amber-400">${data.questions}</div>
        </div>
    `;

    // Show answered players per question
    if (data.answered_players) {
        for (const [questionId, answeredCount] of Object.entries(data.answered_players)) {
            const percentage = Math.round((answeredCount / data.total_players) * 100);
            html += `
                <div class="flex items-center justify-between p-4 bg-night-700/40 border border-gray-700/60 rounded-lg">
                    <div>
                        <div class="font-medium text-gray-100">Frage ${questionId}</div>
                        <div class="text-sm text-gray-400">${answeredCount}/${data.total_players} beantwortet</div>
                    </div>
                    <div class="text-right">
                        <div class="text-lg font-bold text-gray-100">${percentage}%</div>
                        <div class="w-20 bg-night-600 rounded-full h-2 mt-1">
                            <div class="bg-gradient-to-r from-party-purple to-party-pink h-2 rounded-full" style="width: ${percentage}%"></div>
                        </div>
                    </div>
                </div>
            `;
        }
    }

    if (data.all_answered) {
        html += `
            <div class="bg-emerald-500/10 border border-emerald-500/40 rounded-lg p-4">
                <div class="flex items-center">
                    <div class="text-emerald-400 mr-3">✅</div>
                    <div>
                        <div class="font-medium text-emerald-300">Alle haben geantwortet!</div>
                        <div class="text-sm text-emerald-400">Die Ergebnisse können jetzt berechnet werden.</div>
                    </div>
                </div>
            </div>
        `;
    }

    container.innerHTML = html;
}
</script>
{% endblock %}