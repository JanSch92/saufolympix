{% extends 'base.html.twig' %}

{% block title %}Gamechanger Setup - {{ game.name }}{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8">
    <!-- Header -->
    <div class="mb-8">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-extrabold gradient-text">Gamechanger Setup</h1>
                <p class="text-lg text-gray-400 mt-2">{{ game.name }} - {{ game.olympix.name }}</p>
            </div>
            <a href="{{ path('app_game_admin', {id: game.olympix.id}) }}"
               class="btn-secondary">
                ← Zurück zur Übersicht
            </a>
        </div>
    </div>

    <!-- Spielregeln -->
    <div class="bg-party-purple/10 border border-party-purple/30 rounded-lg p-6 mb-8">
        <h2 class="text-xl font-bold text-purple-300 mb-4">Spielregeln Gamechanger</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-sm">
            <div>
                <h3 class="font-semibold text-purple-300 mb-2">Spielablauf:</h3>
                <ul class="space-y-1 text-purple-200">
                    <li>• Jeder Spieler wirft <strong>genau einmal</strong></li>
                    <li>• Zufällige Spielerreihenfolge wird festgelegt</li>
                    <li>• Punkte werden nach jedem Wurf eingegeben</li>
                    <li>• Sofortige Neuberechnung der Rangliste</li>
                </ul>
            </div>
            <div>
                <h3 class="font-semibold text-purple-300 mb-2">Scoring-Regeln:</h3>
                <ul class="space-y-1 text-purple-200">
                    <li>• <strong>Eigene Punkte treffen:</strong> +8 Punkte für dich</li>
                    <li>• <strong>Andere Spieler treffen:</strong> -4 Punkte für sie</li>
                    <li>• <strong>Sonst:</strong> Keine Punkte (weder plus noch minus)</li>
                    <li>• <strong>Punkte können nicht unter 0 fallen</strong></li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Aktuelle Spieler & ihre Punkte -->
    <div class="card p-6 mb-8">
        <h2 class="text-xl font-bold text-gray-100 mb-4">Spieler & aktuelle Punkte</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {% for player in players %}
            <div class="bg-night-700/40 border border-gray-700/60 rounded-lg p-4 text-center">
                <div class="text-lg font-semibold text-gray-100">{{ player.name }}</div>
                <div class="text-2xl font-bold text-amber-400 mt-2">{{ player.totalPoints }} Punkte</div>
                <div class="text-sm text-emerald-400 mt-1 font-semibold">Ziel für +8 Punkte</div>
            </div>
            {% endfor %}
        </div>
        {% if players|length == 0 %}
        <div class="text-center text-gray-500">
            <p>Keine Spieler vorhanden. Bitte füge zuerst Spieler hinzu.</p>
        </div>
        {% endif %}
    </div>

    {% if existing_throws|length > 0 %}
    <!-- Vorhandene Reihenfolge anzeigen -->
    <div class="bg-amber-500/10 border border-amber-500/40 rounded-lg p-6 mb-8">
        <h2 class="text-xl font-bold text-amber-300 mb-4">Aktueller Spielstand</h2>

        {% set realThrows = existing_throws|filter(t => t.thrownPoints > 0) %}
        {% if realThrows|length > 0 %}
        <div class="mb-6">
            <div class="text-sm text-amber-200 mb-3">
                Spielfortschritt: {{ realThrows|length }} von {{ players|length }} Spielern haben geworfen
            </div>
            <div class="bg-night-800/60 border border-gray-700/60 rounded-lg p-4">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                    {% for throw in existing_throws|sort((a, b) => a.playerOrder <=> b.playerOrder) %}
                    <div class="bg-night-700/40 rounded-lg p-3 text-center border {{ throw.thrownPoints > 0 ? 'border-emerald-500/40' : 'border-gray-700/60' }}">
                        <div class="text-sm text-gray-500">{{ throw.playerOrder }}. Spieler</div>
                        <div class="font-semibold text-gray-100">{{ throw.player.name }}</div>
                        {% if throw.thrownPoints > 0 %}
                            <div class="text-emerald-400 text-sm mt-1 font-semibold">
                                {{ throw.thrownPoints }} Punkte
                            </div>
                            <div class="text-xs text-gray-500 mt-1">
                                {{ throw.scoringReason }}
                            </div>
                        {% else %}
                            <div class="text-gray-500 text-sm mt-1">Wartet</div>
                        {% endif %}
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>
        {% else %}
        <div class="mb-6">
            <div class="text-sm text-amber-200 mb-3">
                Spielerreihenfolge wurde festgelegt, aber noch niemand hat geworfen:
            </div>
            <div class="bg-night-800/60 border border-gray-700/60 rounded-lg p-4">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                    {% for throw in existing_throws|sort((a, b) => a.playerOrder <=> b.playerOrder) %}
                    <div class="bg-night-700/40 rounded-lg p-3 text-center border border-gray-700/60">
                        <div class="text-sm text-gray-500">{{ throw.playerOrder }}. Spieler</div>
                        <div class="font-semibold text-gray-100">{{ throw.player.name }}</div>
                        <div class="text-gray-500 text-sm mt-1">Wartet</div>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>
        {% endif %}

        {% if game.status == 'active' %}
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="{{ path('app_gamechanger_play', {gameId: game.id}) }}"
               class="btn-primary inline-block text-center">
                Spiel fortsetzen
            </a>
            {% if realThrows|length > 0 %}
            <button onclick="if(confirm('Wirklich alle Würfe zurücksetzen? Das Spiel startet komplett neu!')) { window.location.href = window.location.href; }"
                    class="btn-secondary">
                Komplett neu starten
            </button>
            {% endif %}
        </div>
        {% endif %}
    </div>
    {% endif %}

    <!-- Setup Aktionen -->
    <div class="card p-6">
        <h2 class="text-xl font-bold text-gray-100 mb-4">Spiel starten</h2>

        {% if players|length < 2 %}
        <div class="bg-red-500/10 border border-red-500/40 rounded-lg p-4 mb-6">
            <p class="text-pink-300">
                <strong>Fehler:</strong> Du brauchst mindestens 2 Spieler für ein Gamechanger-Spiel.
                Aktuell sind nur {{ players|length }} Spieler vorhanden.
            </p>
            <div class="mt-3">
                <a href="{{ path('app_player_manage', {olympixId: game.olympix.id}) }}"
                   class="btn-primary text-sm">
                    Spieler hinzufügen
                </a>
            </div>
        </div>
        {% else %}

        {% if existing_throws|length > 0 %}
        <div class="bg-amber-500/10 border border-amber-500/40 rounded-lg p-4 mb-6">
            <p class="text-amber-300">
                <strong>Achtung:</strong> Es ist bereits eine Spielerreihenfolge festgelegt{% if existing_throws|filter(t => t.thrownPoints > 0)|length > 0 %} und {{ existing_throws|filter(t => t.thrownPoints > 0)|length }} Spieler haben bereits geworfen{% endif %}.
                Beim Neustart wird eine neue zufällige Reihenfolge generiert und alle bisherigen Würfe gelöscht.
            </p>
        </div>
        {% endif %}

        <form method="post" class="space-y-6">
            <div class="text-center">
                <div class="mb-4">
                    <p class="text-gray-400 mb-2">
                        Teilnehmende Spieler: <strong class="text-gray-100">{{ players|length }}</strong>
                    </p>
                    <div class="flex flex-wrap justify-center gap-2 text-sm">
                        {% for player in players %}
                        <span class="bg-party-purple/20 text-purple-300 px-2 py-1 rounded">{{ player.name }}</span>
                        {% endfor %}
                    </div>
                </div>

                <button type="submit"
                        class="btn-primary text-lg px-8 py-3"
                        onclick="return confirm('{% if existing_throws|length > 0 %}Wirklich neu starten? Alle bisherigen Würfe werden gelöscht!{% else %}Spiel mit zufälliger Reihenfolge starten?{% endif %}')">
                    {% if existing_throws|length > 0 %}
                        Spiel neu starten
                    {% else %}
                        Zufällige Reihenfolge festlegen & Starten
                    {% endif %}
                </button>
            </div>
        </form>

        <div class="mt-8 text-center text-sm text-gray-500">
            <p>Nach dem Start werden alle Spieler in zufälliger Reihenfolge sortiert.</p>
            <p>Das Spiel ist beendet, sobald jeder Spieler einmal geworfen hat.</p>
            <p class="mt-2 font-semibold text-gray-400">Die Punkte werden direkt in die Gesamtwertung eingerechnet!</p>
        </div>
        {% endif %}
    </div>

    {% if existing_throws|length > 0 and existing_throws|filter(t => t.thrownPoints > 0)|length > 0 %}
    <!-- Aktuelle Punkte Übersicht -->
    <div class="card p-6 mt-8">
        <h2 class="text-xl font-bold text-gray-100 mb-4">Aktuelle Auswirkungen</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {% for player in players|sort((a, b) => b.totalPoints <=> a.totalPoints) %}
            <div class="bg-night-700/40 border border-gray-700/60 rounded-lg p-4 text-center">
                <div class="text-lg font-semibold text-gray-100">{{ player.name }}</div>
                <div class="text-2xl font-bold text-amber-400 mt-2">{{ player.totalPoints }} Punkte</div>

                <!-- Zeige wenn dieser Spieler schon geworfen hat -->
                {% for throw in existing_throws %}
                    {% if throw.player.id == player.id and throw.thrownPoints > 0 %}
                        <div class="text-sm text-emerald-400 mt-1">
                            Geworfen: {{ throw.thrownPoints }}
                        </div>
                        <div class="text-xs text-gray-500">
                            {{ throw.scoringReason }}
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}