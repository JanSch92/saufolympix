{% extends 'base.html.twig' %}

{% block title %}🤝 Split or Steal Setup - {{ game.name }}{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto">
    <!-- Header -->
    <div class="card p-6 mb-8">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-extrabold gradient-text">🤝 Split or Steal Setup</h1>
                <p class="text-gray-400 mt-1">{{ game.name }}</p>
            </div>
            <div class="flex space-x-4">
                <a href="{{ path('app_game_admin', {id: game.olympix.id}) }}"
                   class="btn-secondary">
                    ← Zurück
                </a>
                {% if existing_matches %}
                    <a href="{{ path('app_split_or_steal_reset', {gameId: game.id}) }}"
                       class="btn-danger"
                       onclick="return confirm('Alle Matches zurücksetzen?')">
                        🔄 Zurücksetzen
                    </a>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- Game Info -->
    <div class="bg-party-purple/10 border border-party-purple/30 rounded-lg p-4 mb-8">
        <div class="flex items-center mb-2">
            <div class="text-purple-300 mr-2">ℹ️</div>
            <h3 class="font-semibold text-purple-300">🤝 Split or Steal Regeln</h3>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-sm text-purple-200">
            <div class="bg-night-800/60 border border-gray-700/60 rounded p-3">
                <div class="font-medium text-emerald-400">🤝 Beide Split</div>
                <div>Jeder bekommt die Hälfte der Punkte</div>
            </div>
            <div class="bg-night-800/60 border border-gray-700/60 rounded p-3">
                <div class="font-medium text-pink-400">💰 Einer Split, einer Steal</div>
                <div>Steal-Spieler bekommt alle Punkte</div>
            </div>
            <div class="bg-night-800/60 border border-gray-700/60 rounded p-3">
                <div class="font-medium text-gray-300">🚫 Beide Steal</div>
                <div>Keiner bekommt Punkte</div>
            </div>
        </div>
    </div>

    <!-- Players Overview -->
    <div class="card p-6 mb-8">
        <h2 class="text-lg font-bold text-gray-100 mb-4">👥 Verfügbare Spieler</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {% for player in players %}
                <div class="bg-night-700/40 border border-gray-700/60 rounded-lg p-4">
                    <div class="font-medium text-gray-100">{{ player.name }}</div>
                    <div class="text-sm text-gray-400">{{ player.totalPoints }} Punkte</div>
                </div>
            {% endfor %}
        </div>

        <div class="mt-4 p-3 bg-amber-500/10 border border-amber-500/40 rounded">
            <div class="text-sm text-amber-300">
                <strong>Hinweis:</strong> Bei ungerader Spielerzahl bleibt ein Spieler ohne Match.
                Aktuell: {{ players|length }} Spieler → {{ (players|length / 2)|round(0, 'floor') }} Matches möglich.
            </div>
        </div>
    </div>

    <!-- Setup Form -->
    <div class="card p-6 mb-8">
        <h2 class="text-lg font-bold text-gray-100 mb-4">⚙️ Spiel konfigurieren</h2>

        <form method="POST" class="space-y-4">
            <div>
                <label for="points_at_stake" class="block text-sm font-medium text-gray-300 mb-2">
                    ✨ Punkte pro Match *
                </label>
                <input type="number"
                       id="points_at_stake"
                       name="points_at_stake"
                       value="50"
                       min="1"
                       max="1000"
                       class="w-full">
                <div class="text-sm text-gray-400 mt-1">
                    Diese Punkte stehen in jedem Match zur Verfügung
                </div>
            </div>

            <div class="bg-night-700/40 border border-gray-700/60 rounded-lg p-4">
                <h3 class="font-semibold text-gray-100 mb-2">Beispiel-Rechnung:</h3>
                <div class="text-sm text-gray-400 space-y-1">
                    <div>• Bei 50 Punkten pro Match und 4 Spielern (2 Matches):</div>
                    <div>• Maximum mögliche Punkte: 100 (wenn alle Steal gegen Split spielen)</div>
                    <div>• Fairste Verteilung: 50 (wenn alle Split spielen)</div>
                    <div>• Minimum: 0 (wenn alle Steal spielen)</div>
                </div>
            </div>

            <div class="flex justify-end space-x-4">
                <a href="{{ path('app_game_admin', {id: game.olympix.id}) }}"
                   class="btn-secondary">
                    Abbrechen
                </a>
                <button type="submit" class="btn-primary">
                    🎲 Zufällige Paarungen erstellen
                </button>
            </div>
        </form>
    </div>

    <!-- Existing Matches -->
    {% if existing_matches %}
    <div class="card p-6">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-bold text-gray-100">🎯 Aktuelle Paarungen</h2>
            <div class="text-sm text-gray-400">
                {{ existing_matches|length }} Matches
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
            {% for match in existing_matches %}
            <div class="border rounded-lg p-4 {% if match.isCompleted %}bg-emerald-500/10 border-emerald-500/40{% elseif match.bothPlayersHaveChosen %}bg-amber-500/10 border-amber-500/40{% else %}bg-night-700/40 border-gray-700/60{% endif %}">
                <div class="flex items-center justify-between mb-3">
                    <div class="text-sm font-medium text-gray-400">
                        Match {{ loop.index }}
                    </div>
                    <div class="text-lg font-bold text-amber-400">
                        {{ match.pointsAtStake }} Punkte
                    </div>
                </div>

                <div class="text-center">
                    <div class="font-semibold text-gray-100 mb-1">
                        {{ match.player1.name }}
                        {% if match.player1Choice %}
                            <span class="text-xs px-2 py-1 rounded-full {% if match.player1Choice == 'split' %}bg-emerald-500/20 text-emerald-300{% else %}bg-red-500/20 text-pink-300{% endif %}">
                                {% if match.isCompleted %}
                                    {{ match.player1Choice|upper }}
                                {% else %}
                                    ✓
                                {% endif %}
                            </span>
                        {% endif %}
                    </div>
                    <div class="text-gray-500 text-sm my-2">VS</div>
                    <div class="font-semibold text-gray-100 mb-3">
                        {{ match.player2.name }}
                        {% if match.player2Choice %}
                            <span class="text-xs px-2 py-1 rounded-full {% if match.player2Choice == 'split' %}bg-emerald-500/20 text-emerald-300{% else %}bg-red-500/20 text-pink-300{% endif %}">
                                {% if match.isCompleted %}
                                    {{ match.player2Choice|upper }}
                                {% else %}
                                    ✓
                                {% endif %}
                            </span>
                        {% endif %}
                    </div>
                </div>

                {% if match.isCompleted %}
                <div class="mt-4 p-3 bg-emerald-500/10 border border-emerald-500/30 rounded-lg">
                    <div class="text-sm font-medium text-emerald-300 text-center mb-2">
                        {{ match.resultDescription }}
                    </div>
                    <div class="text-xs text-emerald-400 text-center">
                        {{ match.player1.name }}: {{ match.player1Points }} Punkte |
                        {{ match.player2.name }}: {{ match.player2Points }} Punkte
                    </div>
                </div>
                {% elseif match.bothPlayersHaveChosen %}
                <div class="mt-4 p-3 bg-amber-500/10 border border-amber-500/30 rounded-lg">
                    <div class="text-sm text-amber-300 text-center">
                        ⏳ Beide haben gewählt - Bereit für Auswertung
                    </div>
                </div>
                {% else %}
                <div class="mt-4 p-3 bg-night-700/40 border border-gray-700/60 rounded-lg">
                    <div class="text-sm text-gray-300 text-center">
                        {% if match.player1Choice %}
                            ✅ {{ match.player1.name }} hat gewählt
                        {% else %}
                            ⏳ {{ match.player1.name }} muss noch wählen
                        {% endif %}
                        <br>
                        {% if match.player2Choice %}
                            ✅ {{ match.player2.name }} hat gewählt
                        {% else %}
                            ⏳ {{ match.player2.name }} muss noch wählen
                        {% endif %}
                    </div>
                </div>
                {% endif %}
            </div>
            {% endfor %}
        </div>

        <!-- Action Buttons -->
        <div class="flex justify-center space-x-4">
            {% set allCompleted = true %}
            {% set allChosen = true %}
            {% for match in existing_matches %}
                {% if not match.isCompleted %}
                    {% set allCompleted = false %}
                {% endif %}
                {% if not match.bothPlayersHaveChosen %}
                    {% set allChosen = false %}
                {% endif %}
            {% endfor %}

            {% if allCompleted %}
                <a href="{{ path('app_split_or_steal_results', {gameId: game.id}) }}"
                   class="btn-success">
                    📊 Ergebnisse anzeigen
                </a>
            {% elseif allChosen %}
                <a href="{{ path('app_split_or_steal_evaluate', {gameId: game.id}) }}"
                   class="btn-success">
                    ✅ Jetzt auswerten
                </a>
            {% else %}
                <div class="text-center">
                    <div class="text-gray-400 mb-2">
                        Warte auf alle Spieler-Entscheidungen...
                    </div>
                    <a href="{{ path('app_split_or_steal_admin', {gameId: game.id}) }}"
                       class="btn-secondary">
                        📱 Admin-Übersicht
                    </a>
                </div>
            {% endif %}
        </div>
    </div>
    {% endif %}
</div>

<script>
// Auto-refresh page every 30 seconds if there are pending matches
{% if existing_matches and not allCompleted %}
    setInterval(function() {
        location.reload();
    }, 30000);
{% endif %}

// Form validation
document.addEventListener('DOMContentLoaded', function() {
    const form = document.querySelector('form');
    const pointsInput = document.getElementById('points_at_stake');

    form.addEventListener('submit', function(e) {
        const points = parseInt(pointsInput.value);

        if (points < 1 || points > 1000) {
            e.preventDefault();
            alert('Punkte müssen zwischen 1 und 1000 liegen');
            return;
        }

        const playerCount = {{ players|length }};
        if (playerCount < 2) {
            e.preventDefault();
            alert('Mindestens 2 Spieler erforderlich');
            return;
        }

        if (playerCount % 2 !== 0) {
            const proceed = confirm(`Bei ${playerCount} Spielern bleibt ein Spieler ohne Match. Trotzdem fortfahren?`);
            if (!proceed) {
                e.preventDefault();
                return;
            }
        }

        const proceed = confirm('Neue Paarungen erstellen? Bestehende Matches werden überschrieben.');
        if (!proceed) {
            e.preventDefault();
        }
    });
});
</script>
{% endblock %}