{% extends 'base.html.twig' %}

{% block title %}{{ olympix.name }} - Admin{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="card p-6 mb-8">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-extrabold gradient-text">🍻 {{ olympix.name }}</h1>
                <p class="text-gray-400 mt-2">⚙️ Admin-Bereich</p>
            </div>
            <div class="flex space-x-4">
                <a href="{{ path('app_show_olympix', {id: olympix.id}) }}" 
                   class="btn-secondary" 
                   target="_blank">
                    📺 Live-Anzeige
                </a>
                <a href="{{ path('app_player_manage', {olympixId: olympix.id}) }}" 
                   class="btn-primary">
                    👥 Spieler verwalten
                </a>
            </div>
        </div>
    </div>

    <!-- QR-Code für Spieler-Zugang -->
    <div class="card p-6 mb-8">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-bold text-gray-100">📱 Spieler-Zugang</h2>
            <button onclick="showQRCode()" class="btn-primary">
                📱 QR-Code anzeigen
            </button>
        </div>
        
        <div id="qrCodeModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
            <div class="card card-highlight p-8 max-w-md w-full">
                <div class="text-center">
                    <h3 class="text-lg font-bold text-gray-100 mb-4">📱 Spieler-Zugang QR-Code</h3>
                    <div id="playerQRCode" class="mb-4 qr-code-container"></div>
                    <p class="text-sm text-gray-400 mb-4">
                        Spieler können diesen Code scannen um ihre Punkte zu sehen und Joker zu verwenden
                    </p>
                    <div class="flex space-x-4">
                        <button onclick="hideQRCode()" class="btn-secondary flex-1">
                            Schließen
                        </button>
                        <button onclick="copyPlayerLink()" class="btn-primary flex-1">
                            Link kopieren
                        </button>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="text-sm text-gray-400">
            <strong>Direkt-Link:</strong>
            <code class="bg-night-700/60 border border-gray-700/60 text-purple-200 p-1 rounded text-xs">{{ url('app_player_access', {olympixId: olympix.id}) }}</code>
        </div>
    </div>
    
    <!-- Enhanced Quick Stats -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="card p-6">
            <div class="flex items-center">
                <div class="text-2xl mr-3">👥</div>
                <div>
                    <div class="text-2xl font-bold text-gray-100">{{ players|length }}</div>
                    <div class="text-sm text-gray-400">Spieler</div>
                </div>
            </div>
        </div>
        
        <div class="card p-6">
            <div class="flex items-center">
                <div class="text-2xl mr-3">🎮</div>
                <div>
                    <div class="text-2xl font-bold text-gray-100">{{ games|length }}</div>
                    <div class="text-sm text-gray-400">Spiele</div>
                </div>
            </div>
        </div>
        
        <div class="card p-6">
            <div class="flex items-center">
                <div class="text-2xl mr-3">✅</div>
                <div>
                    <div class="text-2xl font-bold text-gray-100">
                        {{ games|filter(game => game.status == 'completed')|length }}
                    </div>
                    <div class="text-sm text-gray-400">Abgeschlossen</div>
                </div>
            </div>
        </div>
        
        <div class="card p-6">
            <div class="flex items-center">
                <div class="text-2xl mr-3">🏆</div>
                <div>
                    <div class="text-2xl font-bold text-gray-100">
                        {% if players|length > 0 %}
                            {{ players|first.name }}
                        {% else %}
                            -
                        {% endif %}
                    </div>
                    <div class="text-sm text-gray-400">Führender</div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Progress Bar -->
    <div class="card p-6 mb-8">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-bold text-gray-100">📊 Fortschritt</h2>
            <div class="text-sm text-gray-400">
                {{ games|filter(game => game.status == 'completed')|length }} von {{ games|length }} Spielen
            </div>
        </div>
        
        {% set completedGames = games|filter(game => game.status == 'completed')|length %}
        {% set totalGames = games|length %}
        {% set progressPercentage = totalGames > 0 ? (completedGames / totalGames * 100)|round : 0 %}
        
        <div class="w-full bg-night-700 rounded-full h-4">
            <div class="bg-gradient-to-r from-party-purple via-party-pink to-party-amber h-4 rounded-full transition-all duration-300" style="width: {{ progressPercentage }}%"></div>
        </div>
        <div class="text-center text-sm text-gray-400 mt-2">{{ progressPercentage }}% abgeschlossen</div>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Games Management mit Drag & Drop -->
        <div class="lg:col-span-2">
            <div class="card p-6">
                <div class="flex items-center justify-between mb-6">
                    <h2 class="text-2xl font-bold text-gray-100">🎮 Spiele</h2>
                    <div class="flex space-x-2">
                        <button onclick="saveGamesOrder()" class="btn-success" id="saveOrderBtn" style="display: none;">
                            💾 Reihenfolge speichern
                        </button>
                        <a href="{{ path('app_game_create', {olympixId: olympix.id}) }}" class="btn-primary">
                            ➕ Spiel erstellen
                        </a>
                    </div>
                </div>
                
                <div id="gamesList" class="space-y-4">
                    {% for game in games %}
                        <div class="game-item game-card {% if game.status == 'active' %}active{% elseif game.status == 'completed' %}completed{% endif %}{% if game.isGamechangerGame() %} gamechanger-card{% endif %} p-4 rounded-lg" 
                             data-game-id="{{ game.id }}" 
                             data-order="{{ game.orderPosition }}">
                            <div class="flex items-center">
                                <!-- Drag Handle -->
                                <div class="drag-handle cursor-move text-gray-500 hover:text-gray-200 mr-4 text-xl">
                                    ⋮⋮
                                </div>
                                
                                <div class="flex-1">
                                    <div class="flex items-center justify-between">
                                        <div class="flex-1">
                                            <h3 class="text-lg font-semibold text-gray-100">{{ game.getGameTypeEmoji() }} {{ game.name }}</h3>
                                            <div class="flex items-center space-x-2 mt-1">
                                                <span class="text-sm text-gray-400 capitalize">{{ game.gameType|replace({'_': ' '}) }}</span>
                                                
                                                {% if game.gameType == 'tournament_team' and game.teamSize %}
                                                    <span class="text-xs px-2 py-1 bg-party-purple/10 text-purple-300 rounded">
                                                        {{ game.teamSize }}er Teams
                                                    </span>
                                                {% endif %}
                                                
                                                {% if game.gameType == 'gamechanger' %}
                                                    <span class="gamechanger-badge">
                                                        🎯 GameChanger
                                                    </span>
                                                {% endif %}
                                                
                                                {% if game.status == 'active' %}
                                                    <span class="text-xs px-2 py-1 bg-emerald-500/10 text-emerald-300 rounded animate-pulse">
                                                        🔴 LIVE
                                                    </span>
                                                {% endif %}
                                            </div>
                                            
                                            <!-- Joker Status for Active Games -->
                                            {% if game.status == 'active' %}
                                                <div class="mt-2 text-xs text-gray-500">
                                                    {% set doubleJokers = 0 %}
                                                    {% set swapJokers = 0 %}
                                                    {% for joker in game.jokers %}
                                                        {% if joker.isUsed %}
                                                            {% if joker.jokerType == 'double' %}
                                                                {% set doubleJokers = doubleJokers + 1 %}
                                                            {% elseif joker.jokerType == 'swap' %}
                                                                {% set swapJokers = swapJokers + 1 %}
                                                            {% endif %}
                                                        {% endif %}
                                                    {% endfor %}
                                                    
                                                    {% if doubleJokers > 0 or swapJokers > 0 %}
                                                        🃏 Aktive Joker: 
                                                        {% if doubleJokers > 0 %}
                                                            <span class="text-pink-400">{{ doubleJokers }}x Doppelt</span>
                                                        {% endif %}
                                                        {% if swapJokers > 0 %}
                                                            {% if doubleJokers > 0 %}, {% endif %}
                                                            <span class="text-purple-300">{{ swapJokers }}x Tausch</span>
                                                        {% endif %}
                                                    {% endif %}
                                                </div>
                                            {% endif %}
                                        </div>
                                        
                                        <div class="flex items-center space-x-2">
                                            {% if game.isGamechangerGame() %}
                                                {% if game.status == 'pending' %}
                                                    <a href="{{ path('app_gamechanger_setup', {gameId: game.id}) }}" 
                                                       class="btn-primary text-sm">
                                                        🚀 Starten
                                                    </a>
                                                {% elseif game.status == 'active' %}
                                                    <a href="{{ path('app_gamechanger_play', {gameId: game.id}) }}" 
                                                       class="btn-success text-sm">
                                                        ▶️ Spielen
                                                    </a>
                                                {% elseif game.status == 'completed' %}
                                                    <a href="{{ path('app_gamechanger_play', {gameId: game.id}) }}" 
                                                       class="btn-secondary text-sm">
                                                        📊 Ergebnisse
                                                    </a>
                                                {% endif %}
                                            {% elseif game.status == 'pending' %}
                                                <a href="{{ path('app_game_start', {id: game.id}) }}" class="btn-success text-sm">
                                                    ▶️ Start
                                                </a>
                                            {% elseif game.status == 'active' %}
                                                <a href="{{ path('app_game_results', {id: game.id}) }}" class="btn-primary text-sm">
                                                    📊 Ergebnisse
                                                </a>
                                                {% if game.isQuizGame %}
                                                    <a href="{{ path('app_quiz_qr', {gameId: game.id}) }}" class="btn-secondary text-sm">
                                                        📱 QR-Code
                                                    </a>
                                                {% endif %}
                                                {% if game.isStopwatchGame %}
                                                    <a href="{{ path('app_stopwatch_manage', {gameId: game.id}) }}" class="btn-secondary text-sm">
                                                        ⏱️ Verwalten
                                                    </a>
                                                {% endif %}
                                                {% if game.isTournamentGame %}
                                                    <a href="{{ path('app_game_bracket', {id: game.id}) }}" class="btn-secondary text-sm">
                                                        🏆 Bracket
                                                    </a>
                                                {% endif %}
                                            {% else %}
                                                <span class="text-sm text-emerald-400 font-medium">✅ Abgeschlossen</span>
                                                <a href="{{ path('app_game_results', {id: game.id}) }}" class="btn-secondary text-sm">
                                                    📊 Ergebnisse
                                                </a>
                                            {% endif %}
                                            
                                            <div class="relative">
                                                <button class="text-gray-500 hover:text-gray-200" onclick="toggleDropdown('game-{{ game.id }}')">
                                                    ⋮
                                                </button>
                                                <div id="game-{{ game.id }}" class="hidden absolute right-0 mt-2 w-48 bg-night-800 border border-party-purple/30 rounded-md shadow-xl z-10">
                                                    <div class="py-1">
                                                        <a href="{{ path('app_game_edit', {id: game.id}) }}" class="block px-4 py-2 text-sm text-gray-200 hover:bg-night-700">
                                                            ✏️ Bearbeiten
                                                        </a>
                                                        {% if game.isQuizGame %}
                                                            <a href="{{ path('app_quiz_questions', {gameId: game.id}) }}" class="block px-4 py-2 text-sm text-gray-200 hover:bg-night-700">
                                                                ❓ Fragen
                                                            </a>
                                                        {% endif %}
                                                        <a href="{{ path('app_joker_manage', {gameId: game.id}) }}" class="block px-4 py-2 text-sm text-gray-200 hover:bg-night-700">
                                                            🃏 Joker
                                                        </a>
                                                        {% if game.status == 'active' %}
                                                            <a href="{{ path('app_game_complete', {id: game.id}) }}" class="block px-4 py-2 text-sm text-amber-300 hover:bg-night-700">
                                                                🏁 Abschließen
                                                            </a>
                                                        {% endif %}
                                                        <a href="{{ path('app_game_delete', {id: game.id}) }}" class="block px-4 py-2 text-sm text-pink-400 hover:bg-night-700" onclick="return confirmDelete('Spiel wirklich löschen?')">
                                                            🗑️ Löschen
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- GameChanger Details -->
                            {% if game.isGamechangerGame() and gamechanger_throws is defined %}
                                <div class="bg-party-purple/10 border border-party-purple/30 rounded-lg p-4 mt-4">
                                    <h4 class="font-semibold text-purple-300 mb-3">🎯 GameChanger Details</h4>
                                    
                                    {% if gamechanger_throws|length > 0 %}
                                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
                                            <div class="text-center">
                                                <div class="text-2xl font-bold text-purple-300">{{ gamechanger_throws|length }}</div>
                                                <div class="text-sm text-purple-300">Würfe gesamt</div>
                                            </div>
                                            <div class="text-center">
                                                <div class="text-2xl font-bold text-emerald-400">{{ gamechanger_stats.bonusHits|default(0) }}</div>
                                                <div class="text-sm text-emerald-400">Bonus-Treffer</div>
                                            </div>
                                            <div class="text-center">
                                                <div class="text-2xl font-bold text-pink-400">{{ gamechanger_stats.penaltyHits|default(0) }}</div>
                                                <div class="text-sm text-pink-400">Strafen-Treffer</div>
                                            </div>
                                        </div>
                                        
                                        <!-- Letzte Würfe -->
                                        <div class="bg-night-800/60 rounded-lg p-3">
                                            <h5 class="font-medium text-gray-100 mb-2">📋 Letzte Würfe:</h5>
                                            <div class="space-y-1 text-sm max-h-32 overflow-y-auto">
                                                {% for throw in gamechanger_throws|filter(t => t.thrownPoints > 0)|slice(-5)|reverse %}
                                                    <div class="flex justify-between items-center py-1 border-b border-gray-700/60 last:border-b-0">
                                                        <span class="font-medium">{{ throw.player.name }}</span>
                                                        <span class="font-mono">{{ throw.thrownPoints }}</span>
                                                        <span class="text-xs {% if throw.pointsScored > 0 %}text-emerald-400{% elseif throw.pointsScored < 0 %}text-pink-400{% else %}text-gray-500{% endif %}">
                                                            {{ throw.scoringReason|slice(0, 25) }}{% if throw.scoringReason|length > 25 %}...{% endif %}
                                                        </span>
                                                    </div>
                                                {% endfor %}
                                            </div>
                                        </div>
                                        
                                        {% if gamechanger_complete %}
                                            <div class="mt-3 text-center">
                                                <span class="inline-block px-3 py-1 bg-emerald-500/10 text-emerald-300 rounded-full text-sm font-medium">
                                                    ✅ Spiel beendet - Alle haben geworfen
                                                </span>
                                            </div>
                                        {% else %}
                                            <div class="mt-3 text-center">
                                                <span class="inline-block px-3 py-1 bg-party-purple/10 text-purple-300 rounded-full text-sm font-medium">
                                                    ⏳ {{ olympix.players|length - gamechanger_throws|filter(t => t.thrownPoints > 0)|length }} Spieler noch ausstehend
                                                </span>
                                            </div>
                                        {% endif %}
                                        
                                    {% else %}
                                        <div class="text-center text-purple-300">
                                            <p class="mb-2">Noch nicht gestartet</p>
                                            <a href="{{ path('app_gamechanger_setup', {gameId: game.id}) }}" 
                                               class="btn-primary text-sm">
                                                Setup starten
                                            </a>
                                        </div>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </div>
                    {% else %}
                        <div class="text-center text-gray-500 py-8">
                            <div class="text-4xl mb-4">🎮</div>
                            <p>Noch keine Spiele erstellt</p>
                            <a href="{{ path('app_game_create', {olympixId: olympix.id}) }}" class="btn-primary mt-4">
                                ➕ Erstes Spiel erstellen
                            </a>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
        
        <!-- Player Rankings & Joker Status -->
        <div class="space-y-6">
            <!-- Player Rankings -->
            <div class="card p-6">
                <div class="flex items-center justify-between mb-6">
                    <h2 class="text-2xl font-bold text-gray-100">🏆 Rangliste</h2>
                    <a href="{{ path('app_player_manage', {olympixId: olympix.id}) }}" 
                       class="btn-secondary">
                        👥 Verwalten
                    </a>
                </div>
                
                <div class="space-y-3">
                    {% for player in players %}
                        <div class="flex items-center justify-between p-3 bg-night-700/40 border border-gray-700/60 rounded-lg">
                            <div class="flex items-center space-x-3">
                                <div class="ranking-badge {% if loop.index == 1 %}ranking-1{% elseif loop.index == 2 %}ranking-2{% elseif loop.index == 3 %}ranking-3{% else %}ranking-default{% endif %}">
                                    {{ loop.index }}
                                </div>
                                <div>
                                    <div class="font-medium text-gray-100">{{ player.name }}</div>
                                    <div class="flex items-center space-x-2">
                                        <span class="text-xs px-2 py-1 rounded {% if player.hasJokerDoubleAvailable %}bg-emerald-500/10 text-emerald-300{% else %}bg-night-700/40 text-gray-500{% endif %}">
                                            🔥 2x {% if player.hasJokerDoubleAvailable %}✓{% else %}✗{% endif %}
                                        </span>
                                        <span class="text-xs px-2 py-1 rounded {% if player.hasJokerSwapAvailable %}bg-party-purple/10 text-purple-300{% else %}bg-night-700/40 text-gray-500{% endif %}">
                                            ⇄ Swap {% if player.hasJokerSwapAvailable %}✓{% else %}✗{% endif %}
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <div class="text-lg font-bold text-amber-300">{{ player.totalPoints }}</div>
                        </div>
                    {% else %}
                        <div class="text-center text-gray-500 py-8">
                            <div class="text-4xl mb-4">👥</div>
                            <p>Noch keine Spieler hinzugefügt</p>
                            <a href="{{ path('app_player_manage', {olympixId: olympix.id}) }}" 
                               class="btn-primary mt-4">
                                ➕ Spieler hinzufügen
                            </a>
                        </div>
                    {% endfor %}
                </div>
            </div>
            
            <!-- Current Game Status -->
            <div class="card p-6">
                <h3 class="text-lg font-bold text-gray-100 mb-4">🎯 Aktueller Status</h3>
                
                {% set currentGame = null %}
                {% set nextGame = null %}
                {% for game in games %}
                    {% if game.status == 'active' %}
                        {% set currentGame = game %}
                    {% elseif game.status == 'pending' and nextGame is null %}
                        {% set nextGame = game %}
                    {% endif %}
                {% endfor %}
                
                {% if currentGame %}
                    <div class="bg-emerald-500/10 border border-emerald-500/30 rounded-lg p-4 mb-4">
                        <div class="flex items-center justify-between">
                            <div>
                                <div class="font-semibold text-emerald-300">{{ currentGame.getGameTypeEmoji() }} {{ currentGame.name }}</div>
                                <div class="text-sm text-emerald-400">{{ currentGame.gameTypeLabel }}</div>
                            </div>
                            <div class="text-emerald-400">
                                <span class="animate-pulse">🔴</span> LIVE
                            </div>
                        </div>
                    </div>
                {% endif %}
                
                {% if nextGame %}
                    <div class="bg-party-purple/10 border border-party-purple/30 rounded-lg p-4">
                        <div class="flex items-center justify-between">
                            <div>
                                <div class="font-semibold text-purple-300">Nächstes Spiel:</div>
                                <div class="text-sm text-gray-300">{{ nextGame.getGameTypeEmoji() }} {{ nextGame.name }}</div>
                            </div>
                            <div class="text-purple-300">
                                ⏭️
                            </div>
                        </div>
                    </div>
                {% endif %}
                
                {% if not currentGame and not nextGame %}
                    <div class="bg-night-700/40 border border-gray-700/60 rounded-lg p-4">
                        <div class="text-center text-gray-500">
                            <div class="text-2xl mb-2">🏁</div>
                            <div>Alle Spiele abgeschlossen</div>
                        </div>
                    </div>
                {% endif %}
            </div>
            
            <!-- GameChanger Quick Stats Widget -->
            {% set gamechangerGame = null %}
            {% for game in games %}
                {% if game.isGamechangerGame() and game.status == 'active' %}
                    {% set gamechangerGame = game %}
                {% endif %}
            {% endfor %}
            
            {% if gamechangerGame and gamechanger_stats is defined %}
                <div class="gamechanger-card card p-4">
                    <div class="flex items-center justify-between mb-3">
                        <h4 class="font-semibold text-gray-100">🎯 GameChanger Stats</h4>
                        <span class="gamechanger-badge">AKTIV</span>
                    </div>
                    
                    <div class="grid grid-cols-3 gap-3 text-center">
                        <div>
                            <div class="text-lg font-bold text-amber-300">{{ gamechanger_stats.totalThrows|default(0) }}</div>
                            <div class="text-xs text-gray-500">Würfe</div>
                        </div>
                        <div>
                            <div class="text-lg font-bold text-emerald-400">+{{ gamechanger_stats.totalBonusPoints|default(0) }}</div>
                            <div class="text-xs text-gray-500">Bonus</div>
                        </div>
                        <div>
                            <div class="text-lg font-bold text-pink-400">-{{ gamechanger_stats.totalPenaltyPoints|default(0) }}</div>
                            <div class="text-xs text-gray-500">Strafen</div>
                        </div>
                    </div>
                    
                    {% if not gamechanger_complete and gamechangerGame.status == 'active' %}
                        <div class="mt-3">
                            <a href="{{ path('app_gamechanger_play', {gameId: gamechangerGame.id}) }}" 
                               class="btn-primary w-full text-sm">
                                ▶️ Weiter spielen
                            </a>
                        </div>
                    {% endif %}
                </div>
            {% endif %}
            
            <!-- Quick Actions -->
            <div class="card p-6">
                <h3 class="text-lg font-bold text-gray-100 mb-4">⚡ Schnellaktionen</h3>
                
                <div class="space-y-3">
                    <button onclick="refreshAllPlayerScores()" class="w-full btn-secondary text-sm">
                        🔄 Alle Punkte neu berechnen
                    </button>
                    
                    <a href="{{ path('app_show_olympix', {id: olympix.id}) }}" 
                       class="block w-full btn-primary text-sm text-center"
                       target="_blank">
                        📺 Live-Anzeige öffnen
                    </a>
                    
                    {% if currentGame %}
                        <a href="{{ path('app_joker_manage', {gameId: currentGame.id}) }}" 
                           class="block w-full btn-secondary text-sm text-center">
                            🃏 Joker verwalten
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

<!-- External Scripts -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcode/1.5.3/qrcode.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.0/Sortable.min.js"></script>

<style>
.gamechanger-highlight {
    background: linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%);
    color: white;
}

.gamechanger-card {
    border-left: 4px solid #8b5cf6;
}

.gamechanger-badge {
    background: linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%);
    color: white;
    padding: 2px 8px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 600;
}

.game-card {
    background: rgba(31, 24, 54, 0.6);
    border: 1px solid rgba(139, 92, 246, 0.2);
    transition: all 0.3s ease;
}

.game-card:hover {
    border-color: rgba(139, 92, 246, 0.5);
    box-shadow: 0 4px 14px rgba(139, 92, 246, 0.25);
}

.game-card.active {
    border-color: rgba(20, 184, 166, 0.7);
    background-color: rgba(20, 184, 166, 0.08);
}

.game-card.completed {
    border-color: rgba(107, 114, 128, 0.4);
    background-color: rgba(31, 24, 54, 0.4);
}

.ranking-badge {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 600;
    color: white;
}

.ranking-1 { background: linear-gradient(135deg, #fde047, #f59e0b); color: #78350f; box-shadow: 0 0 10px rgba(245, 158, 11, 0.5); }
.ranking-2 { background: linear-gradient(135deg, #e5e7eb, #9ca3af); color: #1f2937; }
.ranking-3 { background: linear-gradient(135deg, #f59e0b, #92400e); }
.ranking-default { background-color: rgba(58, 47, 92, 0.9); color: #c4b5fd; }
</style>

<script>
// QR-Code für Spieler-Zugang
function showQRCode() {
    const playerUrl = '{{ url('app_player_access', {olympixId: olympix.id}) }}';
    document.getElementById('playerQRCode').innerHTML = '';
    
    new QRCode(document.getElementById('playerQRCode'), {
        text: playerUrl,
        width: 256,
        height: 256,
        colorDark: "#000000",
        colorLight: "#ffffff",
        correctLevel: QRCode.CorrectLevel.H
    });
    
    document.getElementById('qrCodeModal').classList.remove('hidden');
}

function hideQRCode() {
    document.getElementById('qrCodeModal').classList.add('hidden');
}

function copyPlayerLink() {
    const playerUrl = '{{ url('app_player_access', {olympixId: olympix.id}) }}';
    navigator.clipboard.writeText(playerUrl).then(() => {
        alert('Link kopiert!');
    });
}

// Refresh all player scores
function refreshAllPlayerScores() {
    if (confirm('Alle Spielerpunkte neu berechnen? Dies kann bei vielen Spielen etwas dauern.')) {
        fetch('/api/olympix/{{ olympix.id }}/refresh', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert('✅ Alle Punkte wurden neu berechnet!');
                location.reload();
            } else {
                alert('❌ Fehler beim Berechnen der Punkte');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('❌ Fehler beim Berechnen der Punkte');
        });
    }
}

// Enhanced Drag & Drop für Spiele-Sortierung
document.addEventListener('DOMContentLoaded', function() {
    if (window.gamesSortableInitialized) return;
    window.gamesSortableInitialized = true;
    
    const gamesList = document.getElementById('gamesList');
    let hasChanges = false;
    
    if (gamesList && gamesList.children.length > 0) {
        new Sortable(gamesList, {
            handle: '.drag-handle',
            animation: 150,
            ghostClass: 'opacity-50',
            chosenClass: 'ring-blue-500',
            onStart: function(evt) {
                evt.item.classList.add('dragging');
            },
            onEnd: function(evt) {
                evt.item.classList.remove('dragging');
                hasChanges = true;
                document.getElementById('saveOrderBtn').style.display = 'block';
                updateOrderNumbers();
            }
        });
    }
    
    function updateOrderNumbers() {
        const items = document.querySelectorAll('.game-item');
        items.forEach((item, index) => {
            item.dataset.order = index + 1;
        });
    }
    
    // Global function für Button
    window.saveGamesOrder = function() {
        if (!hasChanges) return;
        
        const items = document.querySelectorAll('.game-item');
        const orderData = [];
        
        items.forEach((item, index) => {
            orderData.push({
                id: parseInt(item.dataset.gameId),
                order: index + 1
            });
        });
        
        const requestData = {
            olympix_id: {{ olympix.id }},
            games: orderData
        };
        
        fetch('/api/games/update-order', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify(requestData)
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                hasChanges = false;
                document.getElementById('saveOrderBtn').style.display = 'none';
                
                // Success feedback
                const btn = document.getElementById('saveOrderBtn');
                const originalText = btn.textContent;
                btn.textContent = '✅ Gespeichert';
                btn.classList.remove('btn-success');
                btn.classList.add('btn-secondary');
                
                setTimeout(() => {
                    btn.textContent = originalText;
                    btn.classList.remove('btn-secondary');
                    btn.classList.add('btn-success');
                }, 2000);
            } else {
                alert('Fehler beim Speichern: ' + (data.error || 'Unbekannter Fehler'));
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Fehler beim Speichern der Reihenfolge');
        });
    };
});

// Dropdown functions
function toggleDropdown(id) {
    const dropdown = document.getElementById(id);
    const isHidden = dropdown.classList.contains('hidden');
    
    // Close all dropdowns
    document.querySelectorAll('[id^="game-"]').forEach(el => {
        el.classList.add('hidden');
    });
    
    // Toggle current dropdown
    if (isHidden) {
        dropdown.classList.remove('hidden');
    }
}

// Close dropdowns when clicking outside
document.addEventListener('click', function(event) {
    if (!event.target.closest('[onclick*="toggleDropdown"]')) {
        document.querySelectorAll('[id^="game-"]').forEach(el => {
            el.classList.add('hidden');
        });
    }
});

// Auto-refresh every 30 seconds
setInterval(function() {
    // Only refresh if no forms are active
    if (!document.querySelector('form:focus-within')) {
        location.reload();
    }
}, 30000);
</script>
{% endblock %}