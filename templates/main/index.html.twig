{% extends 'base.html.twig' %}

{% block title %}Saufolympix{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto py-8">
    <div class="text-center mb-10">
        <h1 class="text-4xl font-extrabold text-gray-100">Saufolympix</h1>
    </div>

    <!-- Laufende Saufolympix -->
    {% if recent_olympix|length > 0 %}
    <div class="mb-10">
        <h2 class="text-xl font-bold text-gray-100 mb-4">Laufende Saufolympix</h2>

        <div class="space-y-3">
            {% for olympix in recent_olympix %}
                <div class="card p-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                    <div>
                        <div class="text-lg font-semibold text-gray-100">{{ olympix.name }}</div>
                        <div class="text-sm text-gray-400">
                            {{ olympix.players|length }} Spieler · {{ olympix.games|length }} Spiele · {{ olympix.createdAt|date('d.m.Y') }}
                        </div>
                    </div>
                    <div class="flex gap-2 shrink-0">
                        <a href="{{ path('app_show_olympix', {id: olympix.id}) }}" class="btn-secondary">Live-Anzeige</a>
                        <a href="{{ path('app_game_admin', {id: olympix.id}) }}" class="btn-primary">Verwalten</a>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    <!-- Neue Saufolympix erstellen -->
    <div id="create-olympix" class="card p-6">
        <h2 class="text-xl font-bold text-gray-100 mb-4">Neue Saufolympix erstellen</h2>

        <form action="{{ path('app_create_olympix') }}" method="POST">
            <div class="flex flex-col sm:flex-row gap-3">
                <input type="text"
                       id="name"
                       name="name"
                       required
                       placeholder="Name, z.B. Sauf-WM 2026"
                       class="w-full text-lg">
                <button type="submit" class="btn-primary shrink-0">Erstellen</button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
