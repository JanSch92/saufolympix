{# templates/baselive.html.twig #}
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta name="theme-color" content="#0f0a1e">
    <title>{% block title %}Saufolympix{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🍻</text></svg>">

    {# TailwindCSS & QR-Code Library #}
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        night: {
                            950: '#0f0a1e',
                            900: '#171129',
                            800: '#1f1836',
                            700: '#2a2145',
                            600: '#3a2f5c',
                        },
                        party: {
                            purple: '#8b5cf6',
                            pink: '#ec4899',
                            amber: '#f59e0b',
                            teal: '#14b8a6',
                        },
                    },
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                    },
                },
            },
        };
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcode/1.5.3/qrcode.min.js"></script>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            color-scheme: dark;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: radial-gradient(1200px 600px at 80% -10%, rgba(139, 92, 246, 0.18), transparent 60%),
                        radial-gradient(900px 500px at -10% 110%, rgba(236, 72, 153, 0.14), transparent 60%),
                        #0f0a1e;
            color: #e5e7eb;
            margin: 0;
            padding: 0;
            overflow: hidden;
        }

        /* Party Color Palette */
        :root {
            --primary-50: #f5f3ff;
            --primary-500: #8b5cf6;
            --primary-600: #7c3aed;
            --primary-700: #6d28d9;
            --primary-900: #4c1d95;

            --secondary-500: #ec4899;
            --secondary-600: #db2777;

            --success-500: #10b981;
            --success-600: #059669;

            --warning-500: #f59e0b;
            --warning-600: #d97706;

            --error-500: #ef4444;
            --error-600: #dc2626;

            --surface-800: #1f1836;
            --surface-700: #2a2145;
            --surface-600: #3a2f5c;
        }

        /* Professional Loading Spinner */
        .professional-spinner {
            width: 16px;
            height: 16px;
            border: 2px solid rgba(139, 92, 246, 0.25);
            border-top: 2px solid #a78bfa;
            border-radius: 50%;
            animation: professional-spin 1s linear infinite;
        }

        @keyframes professional-spin {
            to { transform: rotate(360deg); }
        }

        /* Professional Flash Messages */
        .flash-message {
            max-width: 90%;
            margin: 0 auto 1rem;
            padding: 1rem 1.25rem;
            border-radius: 0.75rem;
            backdrop-filter: blur(10px);
            border: 1px solid;
            font-weight: 500;
            position: relative;
            overflow: hidden;
        }

        .flash-message::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: currentColor;
        }

        .flash-success {
            background: rgba(16, 185, 129, 0.15);
            color: #6ee7b7;
            border-color: rgba(16, 185, 129, 0.4);
        }

        .flash-error {
            background: rgba(220, 38, 38, 0.15);
            color: #fca5a5;
            border-color: rgba(220, 38, 38, 0.4);
        }

        .flash-warning {
            background: rgba(245, 158, 11, 0.15);
            color: #fcd34d;
            border-color: rgba(245, 158, 11, 0.4);
        }

        .flash-info {
            background: rgba(139, 92, 246, 0.15);
            color: #c4b5fd;
            border-color: rgba(139, 92, 246, 0.4);
        }

        /* Professional Card Components */
        .professional-card {
            background: rgba(31, 24, 54, 0.85);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(139, 92, 246, 0.18);
            border-radius: 1rem;
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.35);
            transition: all 0.3s ease;
        }

        .professional-card:hover {
            border-color: rgba(139, 92, 246, 0.4);
            box-shadow: 0 8px 30px rgba(139, 92, 246, 0.2);
        }

        /* Professional Gradient Text */
        .gradient-text {
            background: linear-gradient(90deg, #a78bfa, #f472b6, #fbbf24);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* Mobile Navigation */
        .mobile-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: rgba(23, 17, 41, 0.95);
            backdrop-filter: blur(20px);
            border-top: 1px solid rgba(139, 92, 246, 0.25);
            display: flex;
            justify-content: space-around;
            padding: 1rem;
            padding-bottom: calc(1rem + env(safe-area-inset-bottom));
            z-index: 50;
        }

        .mobile-nav a {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.25rem;
            color: #9ca3af;
            text-decoration: none;
            transition: all 0.2s ease;
            padding: 0.5rem;
            border-radius: 0.5rem;
        }

        .mobile-nav a:hover,
        .mobile-nav a.active {
            color: #a78bfa;
            background: rgba(139, 92, 246, 0.1);
        }

        /* Professional Scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: rgba(31, 24, 54, 0.3);
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(139, 92, 246, 0.4);
            border-radius: 3px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: rgba(139, 92, 246, 0.6);
        }

        /* Custom scrollbar for mobile */
        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }

        .custom-scrollbar::-webkit-scrollbar-track {
            background: rgba(31, 24, 54, 0.3);
            border-radius: 2px;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(139, 92, 246, 0.4);
            border-radius: 2px;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: rgba(139, 92, 246, 0.6);
        }

        /* Mobile touch scrolling */
        .custom-scrollbar {
            -webkit-overflow-scrolling: touch;
            overflow-y: auto;
        }
    </style>

    {% block stylesheets %}{% endblock %}
</head>
<body>
    <!-- Flash Messages -->
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="flash-message flash-{{ label }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <!-- Main Content: Full Viewport -->
    <main class="w-full h-full">
        {% block body %}{% endblock %}
    </main>

    {% block javascripts %}{% endblock %}
</body>
</html>