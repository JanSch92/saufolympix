{% extends 'baselive.html.twig' %}

{% block title %}Doppelte Punkte Joker - {{ player.name }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .game-option {
            background: rgba(15, 23, 42, 0.85);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(148, 163, 184, 0.14);
            border-radius: 0.75rem;
            box-shadow: 0 4px 18px rgba(0, 0, 0, 0.3);
            transition: border-color 0.2s ease, background 0.2s ease;
            cursor: pointer;
            min-height: 44px;
        }

        .game-option:hover {
            border-color: rgba(99, 102, 241, 0.45);
            background: rgba(30, 41, 59, 0.85);
        }

        .game-option.selected {
            border-color: rgba(16, 185, 129, 0.5);
            background: rgba(16, 185, 129, 0.1);
        }

        .game-option.disabled {
            opacity: 0.5;
            cursor: not-allowed;
            border-color: rgba(220, 38, 38, 0.3);
            background: rgba(220, 38, 38, 0.08);
        }

        .game-option.disabled:hover {
            background: rgba(220, 38, 38, 0.08);
        }

        .points-display {
            background: rgba(211, 166, 37, 0.15);
            color: #d3a625;
            border: 1px solid rgba(211, 166, 37, 0.35);
            padding: 0.25rem 0.75rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 600;
        }
        
        /* MOBILE-OPTIMIERTE CONTAINER */
        .main-container {
            height: 100vh;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }
        
        .form-container {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        
        .content-wrapper {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        
        .content-header {
            flex-shrink: 0;
            padding: 1rem;
            padding-bottom: 0.5rem;
        }
        
        .scrollable-content {
            flex: 1;
            overflow-y: auto;
            padding: 1rem;
            padding-top: 0;
            padding-bottom: 6rem; /* Platz für Mobile Navigation */
            -webkit-overflow-scrolling: touch;
        }
        
        .scrollable-content::-webkit-scrollbar {
            width: 6px;
        }
        
        .scrollable-content::-webkit-scrollbar-track {
            background: rgba(15, 23, 42, 0.3);
        }

        .scrollable-content::-webkit-scrollbar-thumb {
            background: rgba(99, 102, 241, 0.4);
            border-radius: 3px;
        }

        .scrollable-content::-webkit-scrollbar-thumb:hover {
            background: rgba(99, 102, 241, 0.6);
        }

        .mobile-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            height: 4rem;
            background: rgba(15, 23, 42, 0.95);
            backdrop-filter: blur(20px);
            border-top: 1px solid rgba(148, 163, 184, 0.18);
            box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.4);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 100;
            gap: 1rem;
        }

        .mobile-nav a {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: #9ca3af;
            text-decoration: none;
            transition: all 0.3s ease;
            padding: 0.5rem;
            border-radius: 0.5rem;
            min-width: 60px;
            min-height: 44px;
        }

        .mobile-nav a.active {
            color: #818cf8;
        }

        .mobile-nav a:hover {
            background: rgba(99, 102, 241, 0.1);
        }

        .mobile-nav .nav-apply {
            background: #4f46e5;
            color: white !important;
            padding: 0.75rem 1rem;
            min-height: 44px;
            border-radius: 0.75rem;
            font-weight: 600;
            transition: background 0.2s ease;
            cursor: pointer;
            border: none;
            min-width: auto;
        }

        .mobile-nav .nav-apply:hover {
            background: #6366f1;
        }

        .mobile-nav .nav-apply:disabled {
            background: rgba(41, 54, 80, 0.6);
            color: #94a3b8;
            cursor: not-allowed;
        }

        .mobile-nav .nav-apply:disabled:hover {
            background: rgba(41, 54, 80, 0.6);
        }
        
        /* RESPONSIVE */
        @media (max-width: 768px) {
            .content-header {
                padding: 0.75rem;
                padding-bottom: 0.25rem;
            }
            
            .scrollable-content {
                padding: 0.75rem;
                padding-top: 0;
                padding-bottom: 5rem;
            }
            
            .game-option {
                padding: 0.75rem;
            }

            .mobile-nav {
                gap: 0.5rem;
            }
            
            .mobile-nav .nav-apply {
                padding: 0.5rem 0.75rem;
                font-size: 0.875rem;
            }
        }
        
        @media (max-width: 480px) {
            .content-header {
                padding: 0.5rem;
                padding-bottom: 0.25rem;
            }
            
            .scrollable-content {
                padding: 0.5rem;
                padding-top: 0;
                padding-bottom: 4.5rem;
            }
            
            .mobile-nav {
                height: 4.5rem;
                gap: 0.25rem;
            }
            
            .mobile-nav .nav-apply {
                padding: 0.5rem;
                font-size: 0.8rem;
            }
        }
        
        @media (max-width: 360px) {
            .scrollable-content {
                padding-bottom: 4.5rem;
            }
            
            .mobile-nav {
                height: 5rem;
            }
        }
    </style>
{% endblock %}

{% block body %}
<div class="main-container bg-night-950 text-gray-100">

    <!-- Header -->
    <header class="flex-shrink-0 h-16 flex items-center justify-between px-4 bg-night-900/80 backdrop-blur-xl border-b border-party-purple/20">
        <div class="flex items-center space-x-3">
            <div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z"></path>
                </svg>
            </div>
            <div>
                <h1 class="text-lg font-bold gradient-text">Doppelte Punkte Joker</h1>
                <p class="text-xs text-gray-400">{{ player.name }}</p>
            </div>
        </div>

        <div class="flex items-center space-x-2">
            <span class="text-sm font-medium text-amber-300">{{ player.totalPoints }}</span>
            <span class="text-xs text-gray-500">Punkte</span>
        </div>
    </header>

    {% if available_games_with_status is empty %}
        <!-- No Games Available -->
        <div class="flex-1 flex items-center justify-center p-4">
            <div class="professional-card p-8 text-center max-w-md w-full">
                <div class="w-16 h-16 bg-red-600 rounded-2xl flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728L5.636 5.636m12.728 12.728L5.636 5.636"></path>
                    </svg>
                </div>
                <h2 class="text-xl font-bold text-gray-200 mb-2">Keine Spiele verfügbar</h2>
                <p class="text-gray-400 text-sm mb-6">Alle Spiele bereits verwendet oder keine zukünftigen Spiele</p>
            </div>
        </div>
    {% else %}
        <form action="{{ path('app_player_joker_double', {olympixId: olympix.id, playerId: player.id}) }}" 
              method="POST" 
              id="doubleForm" 
              class="form-container">
            
            <!-- Content Wrapper -->
            <div class="content-wrapper">
                <!-- Header -->
                <div class="content-header">
                    <h2 class="text-lg font-semibold text-gray-200 mb-1">Spiel auswählen</h2>
                    <p class="text-sm text-gray-400">Wähle ein Spiel für doppelte Punkte</p>
                </div>
                
                <!-- Scrollable Games List -->
                <div class="scrollable-content">
                    <div class="space-y-3" style="margin-bottom: 100px;">
                        {% for gameData in available_games_with_status %}
                            {% if gameData.game.gameType != 'split_or_steal' %}
                                <label class="game-option block p-4 {% if gameData.has_double_joker %}disabled{% endif %}" 
                                       for="game_{{ gameData.game.id }}">
                                    <input type="radio" 
                                           id="game_{{ gameData.game.id }}"
                                           name="selected_game_id" 
                                           value="{{ gameData.game.id }}"
                                           class="hidden"
                                           {% if gameData.has_double_joker %}disabled{% endif %}
                                           onchange="selectGame(this, {{ gameData.game.id }})">
                                    
                                    <div class="flex items-center space-x-4">
                                        <div class="flex-1 min-w-0">
                                            <div class="font-semibold text-gray-100 text-lg truncate">{{ gameData.game.name }}</div>
                                            <div class="text-sm text-gray-400 mt-1">{{ gameData.game.gameTypeLabel }}</div>
                                            {% if gameData.has_double_joker %}
                                                <div class="text-sm text-pink-300 font-medium mt-1">Joker bereits verwendet</div>
                                            {% else %}
                                                <div class="text-sm text-emerald-300 font-medium mt-1">Joker verfügbar</div>
                                            {% endif %}
                                        </div>
                                        
                                        <div class="text-right">
                                            {% if not gameData.has_double_joker %}
                                                <div class="points-display">2× Punkte</div>
                                            {% endif %}
                                        </div>
                                    </div>
                                </label>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>
            </div>
        </form>
    {% endif %}

    <!-- Mobile Navigation -->
    <div class="mobile-nav">
        <a href="{{ path('app_player_dashboard', {olympixId: olympix.id, playerId: player.id}) }}">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
            </svg>
            <span class="text-xs">Dashboard</span>
        </a>
        
        <button type="button" 
                class="nav-apply" 
                id="navApplyBtn"
                disabled
                onclick="submitForm()">
            <span class="text-xs">Anwenden</span>
        </button>
    </div>
</div>

<script>
    let selectedGameId = null;
    let gameData = {};
    
    {% for gameData in available_games_with_status %}
        {% if gameData.game.gameType != 'split_or_steal' %}
            gameData[{{ gameData.game.id }}] = {
                name: "{{ gameData.game.name }}",
                gameType: "{{ gameData.game.gameType }}",
                hasDoubleJoker: {{ gameData.has_double_joker ? 'true' : 'false' }}
            };
        {% endif %}
    {% endfor %}
    
    function selectGame(radio, gameId) {
        selectedGameId = gameId;
        
        document.querySelectorAll('.game-option').forEach(option => {
            option.classList.remove('selected');
        });
        radio.closest('.game-option').classList.add('selected');
        
        updateNavButton();
    }
    
    function updateNavButton() {
        const navBtn = document.getElementById('navApplyBtn');
        navBtn.disabled = !selectedGameId;
    }
    
    function submitForm() {
        if (!selectedGameId) {
            return;
        }
        
        // Einfach das Form direkt submitten
        document.getElementById('doubleForm').submit();
    }
</script>
{% endblock %}