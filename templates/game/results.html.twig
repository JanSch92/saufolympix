{% extends 'base.html.twig' %}

{% block title %}Ergebnisse - {{ game.name }}{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8">
    <div class="max-w-4xl mx-auto">
        <div class="card p-6">
            <div class="flex items-center justify-between mb-6">
                <h1 class="text-3xl font-bold text-gray-100">
                    Ergebnisse eingeben
                </h1>
                <div class="text-sm text-gray-400">
                    {{ game.name }} ({{ game.gameTypeLabel }})
                </div>
            </div>

            <div class="mb-4">
                <a href="{{ path('app_game_admin', {id: game.olympix.id}) }}"
                   class="btn-secondary">
                    ← Zurück
                </a>
            </div>

            {% if double_jokers is not empty or swap_joker %}
            <div class="mb-6 p-4 bg-party-purple/10 border border-party-purple/30 rounded-lg">
                <h3 class="font-semibold text-purple-300 mb-3">Aktive Joker für dieses Spiel</h3>

                {% if double_jokers is not empty %}
                <div class="mb-2">
                    <h4 class="font-medium text-purple-300 mb-1">Doppelte Punkte Joker</h4>
                    <ul class="text-sm text-gray-300">
                        {% for joker in double_jokers %}
                        <li>• {{ joker.player.name }} bekommt doppelte Punkte</li>
                        {% endfor %}
                    </ul>
                </div>
                {% endif %}

                {% if swap_joker %}
                <div class="mb-2">
                    <h4 class="font-medium text-purple-300 mb-1">⇄ Punkte Tausch</h4>
                    <div class="text-sm text-gray-300">
                        • {{ swap_joker.player.name }} ↔ {{ swap_joker.targetPlayer.name }}
                    </div>
                </div>
                {% endif %}
            </div>
            {% endif %}

            {% if game.isTournamentGame %}
                {% if game.tournament and game.tournament.isCompleted %}
                    <div class="mb-6 p-4 bg-emerald-500/10 border border-emerald-500/30 rounded-lg">
                        <h3 class="font-semibold text-emerald-300 mb-2">Turnier-Ergebnisse</h3>
                        <div class="mb-4">
                            <a href="{{ path('app_game_bracket', {id: game.id}) }}"
                               class="btn-secondary">
                                Bracket anzeigen
                            </a>
                        </div>
                        <div class="text-emerald-300 mb-4">
                            <p class="font-medium">Turnier abgeschlossen</p>
                            <p class="text-sm">Alle Matches sind gespielt. Ergebnisse können gespeichert werden.</p>
                        </div>

                        <form method="post" class="flex space-x-2">
                            <button type="button"
                                    onclick="window.location='{{ path('app_game_admin', {id: game.olympix.id}) }}'"
                                    class="btn-secondary">
                                Abbrechen
                            </button>
                            <button type="submit"
                                    class="btn-success">
                                Turnier-Ergebnisse speichern
                            </button>
                        </form>
                    </div>
                {% else %}
                    <div class="mb-6 p-4 bg-amber-500/10 border border-amber-500/30 rounded-lg">
                        <h3 class="font-semibold text-amber-300 mb-2">Turnier läuft noch</h3>
                        <p class="text-amber-300 mb-4">Das Turnier ist noch nicht abgeschlossen. Beende alle Matches im Bracket.</p>
                        <a href="{{ path('app_game_bracket', {id: game.id}) }}"
                           class="btn-secondary">
                            Bracket anzeigen
                        </a>
                    </div>
                {% endif %}
            {% else %}
                <form method="post" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        {% for player in players %}
                        <div class="bg-night-700/40 border border-gray-700/60 rounded-lg p-4">
                            <div class="flex items-center justify-between mb-3">
                                <h3 class="text-lg font-semibold text-gray-100">{{ player.name }}</h3>
                                <div class="text-sm text-gray-400">{{ player.totalPoints }} Punkte gesamt</div>
                            </div>

                            {% set existingResult = null %}
                            {% for result in existing_results %}
                                {% if result.player.id == player.id %}
                                    {% set existingResult = result %}
                                {% endif %}
                            {% endfor %}

                            <div class="space-y-2">
                                <label class="block text-sm font-medium text-gray-300">Position</label>
                                <select name="positions[{{ player.id }}]"
                                        class="w-full">
                                    <option value="">Nicht teilgenommen</option>
                                    {% for i in 1..players|length %}
                                        <option value="{{ i }}"
                                                {% if existingResult and existingResult.position == i %}selected{% endif %}>
                                            {{ i }}. Platz
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>
                        {% endfor %}
                    </div>

                    <div class="flex justify-end space-x-4">
                        <button type="button"
                                onclick="window.location='{{ path('app_game_admin', {id: game.olympix.id}) }}'"
                                class="btn-secondary">
                            Abbrechen
                        </button>
                        <button type="submit"
                                class="btn-primary">
                            Ergebnisse speichern
                        </button>
                    </div>
                </form>
            {% endif %}

            {% if existing_results is not empty %}
            <div class="mt-8 p-4 bg-night-700/40 border border-gray-700/60 rounded-lg">
                <h3 class="font-semibold text-gray-100 mb-4">Aktuelle Ergebnisse</h3>
                <div class="space-y-2">
                    {% for result in existing_results %}
                    <div class="flex items-center justify-between py-2 px-3 bg-night-800/60 rounded-lg border border-gray-700/60">
                        <div class="flex items-center space-x-3">
                            <div class="w-8 h-8 bg-party-purple/20 text-purple-300 rounded-full flex items-center justify-center font-bold">
                                {{ result.position }}
                            </div>
                            <div>
                                <div class="font-medium text-gray-100">{{ result.player.name }}</div>
                                {% if result.jokerDoubleApplied %}
                                    <div class="text-xs text-amber-300 font-medium">Doppelte Punkte aktiv</div>
                                {% endif %}
                            </div>
                        </div>
                        <div class="text-right">
                            <div class="font-bold text-amber-300">
                                {{ result.finalPoints }} Punkte
                            </div>
                            {% if result.jokerDoubleApplied %}
                                <div class="text-xs text-amber-300">
                                    ({{ result.points }} × 2)
                                </div>
                            {% endif %}
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}